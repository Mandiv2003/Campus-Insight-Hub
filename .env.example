# ============================================================
# Environment variables reference for Smart Campus Hub
# For backend: use application-local.properties instead (see below)
# For CI/CD: set these as GitHub Actions secrets
# ============================================================

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smartcampus
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
JWT_SECRET=change-me-to-any-random-string-at-least-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
